#!/usr/bin/env bash
# Pre-commit hook to check for lint and formatting issues
#
# Install this hook by copying to .git/hooks/pre-commit and making it executable:
#   cp .git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

set -e

echo "Running code quality checks..."

# Get list of Python files being committed
PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$PYTHON_FILES" ]; then
    echo "No Python files to check"
    exit 0
fi

# Run ruff linter on staged Python files
echo "Checking code with ruff..."
ruff check $PYTHON_FILES || {
    echo "❌ Ruff lint issues found"
    echo "Run 'ruff check --fix' to auto-fix"
    echo "Or use 'git commit --no-verify' to skip checks"
    exit 1
}

# Run ruff format check on staged Python files
echo "Checking code formatting with ruff..."
ruff format --check $PYTHON_FILES || {
    echo "❌ Code formatting issues found"
    echo "Run 'ruff format' to auto-format"
    echo "Or use 'git commit --no-verify' to skip checks"
    exit 1
}

echo "✅ All checks passed"
exit 0
